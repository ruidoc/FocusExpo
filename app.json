{
  "expo": {
    "name": "专注契约",
    "slug": "focusvow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "scheme": ["wxdc022c6a39cb32b7", "focusone"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "weixin",
          "weixinULAPI",
          "weixinURLParamsAPI"
        ],
        "NSPhotoLibraryUsageDescription": "此应用需要访问相册来保存截图",
        "NSPhotoLibraryAddUsageDescription": "此应用需要访问相册来保存截图"
      },
      "associatedDomains": [
        "applinks:(focusone.ruidoc.cn)"
      ],
      "bundleIdentifier": "com.focusone",
      "entitlements": {
        "com.apple.developer.family-controls": true,
        "com.apple.security.application-groups": [
          "group.com.focusone"
        ]
      },
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.focusone",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D0D12"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/logo.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "sounds": [],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-native-wechat",
      "expo-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 21
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "focusvow",
          "organization": "freeshore"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "17655fd0-b6e6-4f12-b988-e23ef2f0c593"
      }
    },
    "owner": "freeshore",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/17655fd0-b6e6-4f12-b988-e23ef2f0c593"
    }
  }
}
