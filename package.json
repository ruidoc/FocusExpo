{
  "name": "focusexpo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:prod": "EXPO_PUBLIC_APP_ENV=production expo start",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "build:preview": "eas build --local --platform ios --profile preview --non-interactive 2>&1 | tee build.log",
    "build:preview:quiet": "eas build --local --platform ios --profile preview --non-interactive 2>&1 | grep -E '(error|Error|ERROR|failed|Failed|FAILED)' | head -50",
    "build:prod": "eas build --local --platform ios --profile production",
    "doctor": "npx expo-doctor",
    "prebuild": "expo prebuild --platform ios",
    "submit": "eas submit --platform ios --path",
    "lint": "expo lint",
    "docs": "bash docs/docs.sh",
    "docs:quick": "bash docs/docs.sh quick",
    "docs:examples": "bash docs/docs.sh examples",
    "docs:arch": "bash docs/docs.sh arch",
    "docs:list": "bash docs/docs.sh list"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@miblanchard/react-native-slider": "^2.6.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-segmented-control/segmented-control": "^2.5.7",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@sentry/react-native": "^7.2.0",
    "axios": "^1.9.0",
    "axios-retry": "^4.5.0",
    "dayjs": "^1.11.13",
    "expo": "~54",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "~7.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^2.8.7",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-native-wechat": "^0.2.0",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "^55.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "immer": "^11.1.3",
    "nativewind": "^4.2.1",
    "posthog-react-native": "^4.30.2",
    "posthog-react-native-session-replay": "^1.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.3.1",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-shared-group-preferences": "^1.1.24",
    "react-native-svg": "15.12.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "9",
    "zustand": "^5.0.9",
    "zustand-computed": "^2.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/configure-splash-screen": "^0.6.0",
    "@expo/image-utils": "^0.8.7",
    "@types/react": "~19.1.17",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.1",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-native-wechat",
          "react-native-shared-group-preferences"
        ]
      }
    }
  },
  "private": true
}
